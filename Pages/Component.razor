@using Microsoft.AspNetCore.Components.Forms
@using static InmoCierres.Pages.Home

@foreach (var doc in ChecklistDocs.Where(d => pestanaActiva == "Comprador" ? d.Id != null && d.Id.StartsWith("COMP_") :
d.Id == null || !d.Id.StartsWith("COMP_")))
{
    @* Si está cargado, le ponemos un fondo ligerito y un borde verde sutil *@
    <div class="card mb-3 shadow-sm rounded-4 @(doc.Cargado ? "bg-light border-success border-opacity-50" : "border-0")">
        <div class="card-body">
            <div class="d-flex justify-content-between align-items-start mb-2">
                <div>
                    <h6 class="mb-0 fw-bold">
                        @doc.Nombre
                        @if (doc.Opcional)
                        {
                            <span class="text-muted fw-normal" style="font-size: 0.75rem;">(Si aplica)</span>
                        }
                    </h6>
                    <span class="badge border text-dark mt-1"
                          style="font-size: 0.7rem; background-color: @(doc.Categoria == "NOTARÍA" ? "#e0f2fe" : doc.Categoria == "PERSONAL" ? "#fef08a" : doc.Categoria == "FINANCIERO" ? "#dcfce7" : "#f3f4f6");">
                        @doc.Categoria
                    </span>
                </div>
                @if (doc.Cargado)
                {
                    <i class="bi bi-check-circle-fill text-success fs-4"></i>
                }
            </div>

            <div class="mt-2">
                @if (doc.Cargado)
                {
                    @* SI YA SE CARGÓ: Mostramos los botones de Ver y Reemplazar *@
                    <div class="d-flex gap-2 w-100">
                        <button class="btn btn-sm btn-outline-primary flex-fill rounded-3 fw-bold shadow-sm"
                                @onclick="() => VerDocumento(doc)">
                            <i class="bi bi-eye me-1"></i> Ver
                        </button>
                        <button class="btn btn-sm btn-outline-danger flex-fill rounded-3 fw-bold shadow-sm"
                                @onclick="() => BorrarDocumentoIndividual(doc)">
                            <i class="bi bi-arrow-repeat me-1"></i> Reemplazar
                        </button>
                    </div>
                }
                else
                {
                    @* SI NO SE HA CARGADO: Mostramos el input de subir archivo (SOLO PDF) *@
                    <InputFile OnChange="@(e => HandleFileSelected(e, doc))"        accept="application/pdf, .pdf"
                               class="form-control form-control-sm rounded-3 shadow-sm" />
                }
            </div>
        </div>
    </div>
}