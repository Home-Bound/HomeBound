                                                <span class="badge rounded-pill bg-light text-dark border">@exp.Avance%</span>
                                                <div class="progress flex-grow-1 ms-2" style="height: 6px;">
                                                    <div class="progress-bar bg-warning" style="width: @(exp.Avance)%;"></div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="px-3 pb-3 pt-2">
