@page "/"
@using System.Text.Json
@inject IJSRuntime JSRuntime
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider   

<PageTitle>HomeBound</PageTitle>

<nav class="navbar navbar-dark navbar-custom fixed-top">
    <div class="container-fluid">
        @if (modoCliente)
        {
            <span class="navbar-brand mb-0 h1">
                <i class="bi bi-house-door-fill me-2 text-primary"></i> @expedienteSeleccionado?.PropiedadTitulo
            </span>
        }
        else if (expedienteSeleccionado != null)
        {
            <button class="btn btn-link text-dark p-0 me-3" @onclick="VolverALista">
                <i class="bi bi-arrow-left" style="font-size: 1.5rem;"></i>
            </button>
            <span class="navbar-brand mb-0 h1 text-truncate">@expedienteSeleccionado.PropiedadTitulo</span>
        }
        else
        {
            <a class="navbar-brand p-0" href="#">
                <div class="logo-container">
                    <div class="logo-circle animate__animated animate__fadeInLeft">
                        <img src="logo.png" alt="HomeBound Logo" />
                    </div>
                    <span class="brand-text animate__animated animate__fadeInRight">HomeBound</span>
                </div>
            </a>
        }
    </div>
</nav>

<div class="container" style="margin-top: 120px; margin-bottom: 100px;">

    @if (!modoCliente)
    {
        <AuthorizeView>
            <NotAuthorized>
                <div class="text-center mt-5">
                    <h3 class="fw-bold text-secondary mb-3">Portal de Seguimiento</h3>
                    <button class="btn btn-light shadow border py-2 px-4 d-inline-flex align-items-center gap-2 rounded-pill"
                            @onclick="IniciarSesionGoogle">
                        <span style="color: #DB4437; font-weight:bold; font-size: 1.2rem;">G</span>
                        <span class="fw-bold">Ingresar como Asesor</span>
                    </button>
                </div>
            </NotAuthorized>
            <Authorized>
                <div class="user-panel d-flex justify-content-between align-items-center animate__animated animate__fadeInDown">
                    <div class="d-flex align-items-center gap-3">
                        @if (usuarioGoogle != null && !string.IsNullOrEmpty(usuarioGoogle.FotoUrl))
                        {
                            <img src="@usuarioGoogle.FotoUrl" class="rounded-circle shadow-sm" width="50" height="50"
                                 style="border: 2px solid white;" />
                        }
                        <div>
                            <div class="fw-bold text-dark">@(usuarioGoogle?.Nombre ?? context.User.Identity?.Name)</div>
                            <div class="small text-muted">
                                @if (datosUsuario != null)
                                {
                                    <span class="badge bg-secondary">@datosUsuario.Rol.ToUpper()</span>
                                    <span class="ms-1" style="font-size:0.7rem">@datosUsuario.Empresa</span>
                                }
                                else
                                {
                                    <span class="text-danger">Sin Acceso ⛔</span>
                                }
                            </div>
                        </div>
                    </div>
                    <button class="btn btn-sm btn-outline-secondary rounded-pill px-3" @onclick="CerrarSesion">Salir</button>
                </div>

                @if (datosUsuario == null)
                {
                    <div class="alert alert-warning mt-3 text-center">
                        Hola <strong>@(usuarioGoogle?.Email ?? "")</strong>. <br>
                        No tienes una cuenta activa en el sistema. <br>
                        Contacta a tu Master Broker para que te dé de alta.
                    </div>
                }
            </Authorized>
        </AuthorizeView>
    }

        @if (modoCliente && expedienteSeleccionado != null)
        {
            @* 1. EL CLIENTE ENTRÓ Y EL EXPEDIENTE YA CARGÓ *@
            <div class="text-center mb-4 animate__animated animate__fadeIn">
                <h2 class="fw-bold" style="color: var(--color-primario);">¡Hola, @expedienteSeleccionado.ClienteNombre!</h2>
                <p class="text-muted">Aquí está el avance de tu propiedad.</p>
            </div>
            @RenderizarDetalles(expedienteSeleccionado)
        }
        else if (modoCliente && expedienteSeleccionado == null)
        {
            @* 2. EL CLIENTE ENTRÓ PERO FIREBASE AÚN ESTÁ PENSANDO (Evita la pantalla blanca) *@
            <div class="text-center mt-5 p-5 animate__animated animate__fadeIn">
                <div class="spinner-border" role="status" style="color: var(--color-primario); width: 3rem; height: 3rem;"></div>
                <h5 class="mt-3 text-muted fw-bold">Buscando tu expediente...</h5>
                <p class="text-muted small">Por favor espera un momento.</p>
            </div>
        }
        else if (usuarioGoogle != null && datosUsuario != null) // Solo si está logueado Y registrado en DB
        {
            
            if (modoCreacion)
            {
                <div class="card card-propiedad p-3 animate__animated animate__fadeInUp">
                    <h4 class="fw-bold mb-4" style="color: var(--color-primario);">Nuevo Trámite</h4>

                   <div class="mb-4 text-center">
                        @if (!string.IsNullOrEmpty(nuevoExpediente.FotoPropiedadUrl))
                        {
                            <div class="position-relative">
                                <img src="@nuevoExpediente.FotoPropiedadUrl" class="img-fluid rounded-3 shadow-sm"
                                    style="max-height: 200px;" />
                                <button class="btn btn-danger btn-sm position-absolute top-0 end-0 m-2 rounded-circle"
                                        @onclick="() => nuevoExpediente.FotoPropiedadUrl = null">✕</button>
                            </div>
                        }
                        else
                        {
