                                <i class="bi bi-plus"></i>
                            </button>
                        </div>
                    }

@code {
        // --- NUEVA SEGURIDAD BASADA EN BASE DE DATOS ---
        UsuarioGoogle? usuarioGoogle = null;
        UsuarioPermisos? datosUsuario = null; // Aquí guardamos Rol y Empresa que vienen de la DB

        // Roles definidos
        bool esSuperAdmin => datosUsuario?.Rol == "superadmin"; // TÚ (Ve todo de todas las empresas)
        bool esMaster => datosUsuario?.Rol == "master"; // Jefe de una Inmobiliaria (Ve todo de SU empresa)
        bool esAsesor => datosUsuario?.Rol == "asesor"; // Asesor (Ve solo LO SUYO)

        // Estados
        bool modoCliente = false;
        bool linkCopiado = false;
        bool subiendoFoto = false;
        bool confirmandoBorrado = false;
        bool modoCreacion = false;
        bool mostrarTramitesMuni = false;
        private bool estaEliminando = false; 
        private bool mostrarMenuCreacion = false;
        string nuevoPasoNombre = "";

        // --- MODELOS ---
        public class UsuarioGoogle
        {
            public string Uid { get; set; } = ""; 
            public string Nombre { get; set; } = ""; 
            public string Email { get; set; } = ""; 
            public string FotoUrl { get; set; } = "";
        }

        public class UsuarioPermisos
        {
            public string Rol { get; set; } = "";
            public string Empresa { get; set; } = "";
        }

        public class Paso
        {
            public string Nombre { get; set; } = "";
            public string Tipo { get; set; } = "simple";
            public bool Check1 { get; set; } = false;
            public bool Check2 { get; set; } = false;
            public string ValorDato { get; set; } = "";
            public bool Aplica { get; set; } = true;
            public DateTime? FechaCompletado { get; set; }
        }

        // 📈 NUEVO V2: Modelo para las métricas de marketing
        public class SeguimientoMarketing
        {
            public int VistasOnline { get; set; } = 0;
            public int Interesados { get; set; } = 0;
            public int CitasFisicas { get; set; } = 0;
            public bool CampanaActiva { get; set; } = false;
            public string DetalleCampana { get; set; } = "Preparando estrategia...";
        }

        // 👥 NUEVO V2: Modelo para la bitácora de visitas físicas
        public class ActividadVisita
        {
            public DateTime Fecha { get; set; } = DateTime.Now;
            public string Visitante { get; set; } = "";
            public string Comentarios { get; set; } = "";
            public List<string> Etiquetas { get; set; } = new();
        }

        public class Expediente
        {
            public string Id { get; set; } = Guid.NewGuid().ToString();
            public string AsesorOwnerEmail { get; set; } = "";
            public string EmpresaOwner { get; set; } = ""; 
            public string ClienteNombre { get; set; } = "";
            public string PropiedadTitulo { get; set; } = "";
            public string? FotoPropiedadUrl { get; set; }
            public string NotasBitacora { get; set; } = "";

            // 🧬 NUEVO V2: El ADN del expediente. Por defecto "Cierre" para no romper lo anterior
            public string TipoTramite { get; set; } = "Cierre"; 
            
            // 🎒 NUEVO V2: Mochila de Marketing y Visitas
            public SeguimientoMarketing Marketing { get; set; } = new SeguimientoMarketing();
            public List<ActividadVisita> BitacoraVisitas { get; set; } = new();

            public List<Paso> PasosTramite { get; set; } = new List<Paso>();
            public List<Paso> PasosMunicipales { get; set; } = new List<Paso>();
            public List<DocumentoSimple> Documentos { get; set; } = new();
            public List<string> Colaboradores { get; set; } = new List<string>();

            public int Avance
            {
                get
                {
                    var todos = PasosTramite.Where(p => p.Aplica).ToList();
                    var sub = PasosMunicipales.Where(p => p.Aplica).ToList();
                    int totalPasos = todos.Count + sub.Count;
                    if (totalPasos == 0) return 0;
                    int completados = 0;
                    foreach (var p in todos)
                    {
                        if (p.Tipo == "doble") { if (p.Check1 && p.Check2) completados++; }
                        else { if (p.Check1) completados++; }
                    }
                    foreach (var p in sub) { if (p.Check1) completados++; }
                    return (int)((double)completados / totalPasos * 100);
                }
            }

            public class DocumentoSimple 
            {
                public string Id { get; set; } = string.Empty;
                public bool Cargado { get; set; }
            }

            public Expediente()
            {
                PasosTramite = new List<Paso> {
                    new Paso { Nombre = "Apartado", Tipo = "monto", ValorDato="$50,000" },
                    new Paso { Nombre = "Autorización de Crédito", Tipo = "opcional" },
                    new Paso { Nombre = "Revisión Contrato Promesa", Tipo = "doble" },
                    new Paso { Nombre = "Firma Contrato y Enganche", Tipo = "monto", ValorDato="$" },
                    new Paso { Nombre = "Entrega Docs a Notaría", Tipo = "doble" },
                    new Paso { Nombre = "Fideicomiso", Tipo = "opcional" },
                    new Paso { Nombre = "Firma Escritura", Tipo = "fecha" },
                    new Paso { Nombre = "Entrega de Llaves", Tipo = "simple" },
                    new Paso { Nombre = "Cambio Servic. (Luz/Agua)", Tipo = "simple" }
                };
                
                PasosMunicipales = new List<Paso> {
                    new Paso { Nombre = "Pago Predial", Tipo = "sub" },
                    new Paso { Nombre = "Cédula Catastral", Tipo = "sub" },
                    new Paso { Nombre = "Constancia de nomenclatura", Tipo = "sub" },
                    new Paso { Nombre = "Cambio de Propietario", Tipo = "opcional" },
                    new Paso { Nombre = "Constancia No Adeudo Predial", Tipo = "sub" },
                    new Paso { Nombre = "Constancia Cooperación Obra", Tipo = "sub" },
                    new Paso { Nombre = "Constancia No Adeudo Agua", Tipo = "sub" }
                };
                }
            }
        List<Expediente> listaCompleta = new List<Expediente>();
            Expediente? expedienteSeleccionado = null;
            Expediente nuevoExpediente = new Expediente();

            // =========================================================
            // MÉTODO FUSIONADO (Detecta Cliente y Detecta Sesión)
            // =========================================================
        
            // 1. ESTE ES EL ATRAPADOR DE LA URL (Debe ir suelto aquí en el @code, no dentro de una clase)
            [Parameter]
            public string? Id { get; set; }

            private void ToggleMenu()
        {
            mostrarMenuCreacion = !mostrarMenuCreacion;
        }

        private void SeleccionarTipo(string tipoTramite)
        {
            // 1. Cerramos el menú flotante
            mostrarMenuCreacion = false;
            
            // 2. Aquí llamamos a tu función de crear, pero le pasamos el "ADN"
            IniciarCreacion(tipoTramite);
        }

    protected override async Task OnInitializedAsync()
    {
        string idBuscado = Id ?? "";

        if (string.IsNullOrEmpty(idBuscado))
        {
            var uri = Nav.ToAbsoluteUri(Nav.Uri);
            if (uri.Query.Contains("id="))
            {
                var query = System.Web.HttpUtility.ParseQueryString(uri.Query);
                idBuscado = query["id"] ?? "";
            }
        }

        if (!string.IsNullOrEmpty(idBuscado)) 
        {
            modoCliente = true;
            try 
            {
                var json = await JSRuntime.InvokeAsync<string>("obtenerUnicoExpediente", idBuscado);
                
                if (!string.IsNullOrEmpty(json)) 
                {
                    expedienteSeleccionado = System.Text.Json.JsonSerializer.Deserialize<Expediente>(json);
                }
                else
                {
                    // Si Firebase responde pero viene vacío
                    // Cambia la alerta que tienes por esta:
                await JSRuntime.InvokeVoidAsync("alert", $"⚠️ No se encontró el expediente con ID: '{idBuscado}'. Revisa el enlace.");
                }
            }
            catch (Exception ex)
            {
                // 🚨 ¡ESTO ES CLAVE! Si Firebase bloquea la lectura, el celular nos lanzará una alerta
                await JSRuntime.InvokeVoidAsync("alert", $"Error de conexión con Firebase: {ex.Message}");
            }
        }
        else 
        {
            // Lógica del guardián de sesión para ti (Asesor)
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;

            if (user.Identity != null && user.Identity.IsAuthenticated)
            {
                usuarioGoogle = new UsuarioGoogle 
                { 
                    Uid = user.FindFirst(c => c.Type == System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "",
                    Nombre = user.Identity.Name ?? "",
                    Email = user.FindFirst(c => c.Type == System.Security.Claims.ClaimTypes.Email)?.Value ?? ""
                };

                await RevisarPermisosYCargar();
            }
        }
    }

    // --- FILTRADO MULTI-INMOBILIARIA ---
    List<Expediente> ObtenerExpedientesFiltrados()
    {
        // 1. Si no ha iniciado sesión en Google, no ve nada
        if (usuarioGoogle == null || string.IsNullOrEmpty(usuarioGoogle.Email)) 
            return new List<Expediente>();

        string miCorreo = usuarioGoogle.Email.ToLower();

        // 2. Si eres SUPERADMIN, ves todo el universo
        if (esSuperAdmin) return listaCompleta;

        // 3. LA REGLA INFALIBLE: Si tu correo está en la lista de invitados, O eres el creador, lo ves. (Sin importar la empresa o si sus datos de usuario tardaron en cargar).
        return listaCompleta.Where(x => 
            (x.Colaboradores != null && x.Colaboradores.Contains(miCorreo)) ||
            (x.AsesorOwnerEmail != null && x.AsesorOwnerEmail.ToLower() == miCorreo)
        ).ToList();
    }
    async Task IniciarSesionGoogle()
    {
        try
        {
            usuarioGoogle = await JSRuntime.InvokeAsync<UsuarioGoogle>("loginGoogle");

            if (usuarioGoogle != null)
            {
                if (AuthStateProvider is FirebaseAuthStateProvider provider)
                {
                    provider.NotificarLogin(new UsuarioInfo 
                    { 
                        uid = usuarioGoogle.Uid, 
                        nombre = usuarioGoogle.Nombre, 
                        email = usuarioGoogle.Email, 
                        fotoUrl = usuarioGoogle.FotoUrl 
                    });
                }
                
                await RevisarPermisosYCargar();
            }
        }
        catch { }
    }

    async Task CerrarSesion()
    {
        await JSRuntime.InvokeVoidAsync("logoutFirebase"); 
        
        if (AuthStateProvider is FirebaseAuthStateProvider provider)
        {
            provider.NotificarLogout();
        }

        usuarioGoogle = null; 
        datosUsuario = null; 
        expedienteSeleccionado = null; 
    }

    // 4. REVISAR PERMISOS
    private async Task RevisarPermisosYCargar()
    {
        if (usuarioGoogle == null) return;
        
        var jsonPermisos = await JSRuntime.InvokeAsync<string?>("obtenerRolUsuario", usuarioGoogle.Email);
        if (!string.IsNullOrEmpty(jsonPermisos))
        {
            // 🪄 LENTES MÁGICOS PARA EL TRADUCTOR DE USUARIO
            var opciones = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };
            
            // Usamos las opciones aquí:
            datosUsuario = System.Text.Json.JsonSerializer.Deserialize<UsuarioPermisos>(jsonPermisos, opciones);
            
            // Llama a tu función original para traer los expedientes de Firebase
            await CargarDesdeNube(); 
        }
        else
        {
            datosUsuario = null;
        }
    }
    async Task CargarDesdeNube()
    {
        try
        {
            // 1. Le mandamos el correo a la función para que sepa a quién buscar
            string miCorreo = usuarioGoogle?.Email ?? "";
            var json = await JSRuntime.InvokeAsync<string>("obtenerExpedientesFirestore", miCorreo);
            
            if (!string.IsNullOrEmpty(json))
            {
                // 2. 🪄 LENTES ESPECIALES PARA EL TRADUCTOR
                // Le decimos que no se ponga estricto con las mayúsculas/minúsculas de Firebase
                var opciones = new JsonSerializerOptions 
                { 
                    PropertyNameCaseInsensitive = true 
                };

                listaCompleta = JsonSerializer.Deserialize<List<Expediente>>(json, opciones) ?? new List<Expediente>();
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar: {ex.Message}");
        }
    }

    async Task AutoGuardar() { if (expedienteSeleccionado != null) await GuardarEnNube(expedienteSeleccionado); }
    async Task GuardarEnNube(Expediente? exp)
    {
        if (exp == null) return; var json = JsonSerializer.Serialize(exp); await
    JSRuntime.InvokeVoidAsync("guardarExpedienteFirestore", json);
    }

    void IniciarCreacion(string tipoTramite) 
{ 
    nuevoExpediente = new Expediente(); 
    
    // 🧬 AQUÍ OCURRE LA MAGIA: Le inyectamos el tipo de trámite desde el inicio
    nuevoExpediente.TipoTramite = tipoTramite; 
    
    modoCreacion = true; 
    expedienteSeleccionado = null; 
}
    void CancelarCreacion() => modoCreacion = false;
    void VerDetalles(Expediente exp) { expedienteSeleccionado = exp; modoCreacion = false; }
    void VolverALista() { expedienteSeleccionado = null; modoCreacion = false; confirmandoBorrado = false; }

    async Task GuardarExpediente()
    {
        if (string.IsNullOrWhiteSpace(nuevoExpediente.ClienteNombre)) return;

        // --- GUARDADO INTELIGENTE ---
        // Guardamos quién lo creó Y de qué empresa es
        nuevoExpediente.AsesorOwnerEmail = usuarioGoogle?.Email ?? "";
        nuevoExpediente.EmpresaOwner = datosUsuario?.Empresa ?? "Sin Empresa";

        // --- 🪄 NUEVA MAGIA: COLABORADORES ---
        // Aseguramos que la lista exista
        if (nuevoExpediente.Colaboradores == null)
        {
            nuevoExpediente.Colaboradores = new List<string>();
        }
        
        // Agregamos tu correo a la lista de accesos para que siempre puedas verlo
        if (!string.IsNullOrEmpty(nuevoExpediente.AsesorOwnerEmail))
        {
            nuevoExpediente.Colaboradores.Add(nuevoExpediente.AsesorOwnerEmail.ToLower());
        }

        // --- GUARDADO FINAL ---
        listaCompleta.Add(nuevoExpediente);
        await GuardarEnNube(nuevoExpediente);
        modoCreacion = false;
    }  
    
    async Task EliminarTramite()
    {
        if (expedienteSeleccionado == null) return;

        // 🟢 1. ENCENDEMOS LA PANTALLA NEGRA DE CARGA (El overlay)
        estaEliminando = true;
        StateHasChanged(); 

        try
        {
            // 2. Limpieza de Storage (PDFs)
            if (expedienteSeleccionado.Documentos != null && expedienteSeleccionado.Documentos.Any())
            {
                foreach (var doc in expedienteSeleccionado.Documentos.Where(d => d.Cargado))
                {
                    await JSRuntime.InvokeVoidAsync("borrarArchivoStorage", expedienteSeleccionado.Id, doc.Id);
                }
            }

            // 2.5 Limpieza de la Foto de Perfil
            if (!string.IsNullOrEmpty(expedienteSeleccionado.FotoPropiedadUrl))
            {
                await JSRuntime.InvokeVoidAsync("borrarArchivoPorUrl", expedienteSeleccionado.FotoPropiedadUrl);
            }

            // 3. Borramos de Firestore
            await JSRuntime.InvokeVoidAsync("eliminarExpedienteFirestore", expedienteSeleccionado.Id);

            // 4. Actualizamos la lista
            listaCompleta.Remove(expedienteSeleccionado);
            VolverALista();
            
            await JSRuntime.InvokeVoidAsync("alert", "Expediente eliminado correctamente.");
        }
        catch (Exception ex)
        {
            await JSRuntime.InvokeVoidAsync("alert", $"Hubo un problema: {ex.Message}");
        }
        finally
        {
            // 🔴 5. APAGAMOS LA PANTALLA NEGRA DE CARGA Y RESETEAMOS LA CONFIRMACIÓN
            estaEliminando = false;
            confirmandoBorrado = false; // Lo regresamos a su estado original
            StateHasChanged();
        }
        }
        async Task CargarFoto(InputFileChangeEventArgs e)
        {
        subiendoFoto = true;
        try
        {
            var archivoOriginal = e.File;

            // 1. 🪄 EL COMPRESOR: Forzamos a que sea un JPEG ligero de máximo 800x600 píxeles
            var formato = "image/jpeg";
            var archivoComprimido = await archivoOriginal.RequestImageFileAsync(formato, maxWidth: 800, maxHeight: 600);

            // 2. ABRIMOS LA PUERTA Y LEEMOS EL ARCHIVO COMPRIMIDO
            // Aumentamos el límite de seguridad a 5MB por si la foto original era muy pesada
            using var stream = archivoComprimido.OpenReadStream(maxAllowedSize: 5120000); 
            using var memoryStream = new MemoryStream();
            
            // Usamos CopyToAsync, que es la forma más segura de leer archivos sin que se rompan
            await stream.CopyToAsync(memoryStream);
            var buffer = memoryStream.ToArray();
            
            // 3. CONVERTIMOS A BASE64
            var base64 = Convert.ToBase64String(buffer);
            
            // 4. Le ponemos la extensión .jpg forzosa para que Firebase la reconozca perfecto
            string nombreArchivo = $"{Guid.NewGuid()}.jpg";
            
            // 5. MANDAMOS A JAVASCRIPT / FIREBASE
            string? url = await JSRuntime.InvokeAsync<string?>("subirImagenStorage", nombreArchivo, base64);
            
            if (!string.IsNullOrEmpty(url)) 
            {
                nuevoExpediente.FotoPropiedadUrl = url;
            }
        }
        catch (Exception)
        { 
            // Si quieres ver el error en la consola por si algo falla, descomenta la siguiente línea:
            // Console.WriteLine($"Error al subir foto: {ex.Message}");
        }
        finally
        {
            subiendoFoto = false;
        }
    }

    async Task AgregarPasoExtra()
    {
        if (string.IsNullOrWhiteSpace(nuevoPasoNombre) || expedienteSeleccionado == null) return;
        expedienteSeleccionado.PasosTramite.Add(new Paso { Nombre = nuevoPasoNombre, Tipo = "simple" });
        nuevoPasoNombre = "";
        await AutoGuardar();
    }

    string ObtenerLinkCompartir(string id) => $"{Nav.BaseUri}?id={id}";
    async Task CopiarLink(string id)
    {
        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText",
    ObtenerLinkCompartir(id)); linkCopiado = true; await Task.Delay(2000); linkCopiado = false;
    }

