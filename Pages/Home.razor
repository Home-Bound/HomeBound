                                }
                                else
                                {
                                    <span style="font-size: 2rem;"><i class="bi bi-camera" style="font-size: 2rem;"></i></span>
                                    <span class="small">Subir Foto</span>
                                }
                                <InputFile OnChange="CargarFoto" hidden accept="image/jpeg, image/png, image/webp" />
                            </label>
                        }
                    </div>

                    <input type="text" class="form-control form-control-lg mb-3 bg-light border-0"
