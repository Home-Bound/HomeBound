    new DocEC { Id = "ACT_MAT", Parte = "Vendedor", Categoria = "PERSONAL", Nombre = "Acta de Matrimonio", Opcional = true },
    new DocEC { Id = "EDO_CTA", Parte = "Vendedor", Categoria = "PERSONAL", Nombre = "Último Estado de Cuenta Bancario (3 meses)" },
    new DocEC { Id = "RFC", Parte = "Vendedor", Categoria = "PERSONAL", Nombre = "Constancia de Situación Fiscal Vigente" },
    new DocEC { Id = "CURP", Parte = "Vendedor", Categoria = "PERSONAL", Nombre = "CURP Vigente" },
    new DocEC { Id = "COMP_DOM", Parte = "Vendedor", Categoria = "PERSONAL", Nombre = "Comprobante de Domicilio" },
    new DocEC { Id = "POD", Parte = "Vendedor", Categoria = "PERSONAL", Nombre = "Poder Notarial (si no es propietario)", Opcional = true },

    // --- 2. LEGAL E INMUEBLE ---
    new DocEC { Id = "ESC", Parte = "Vendedor", Categoria = "LEGAL", Nombre = "Título de Propiedad con datos RPP" },
    new DocEC { Id = "CANC_HIP", Parte = "Vendedor", Categoria = "LEGAL", Nombre = "Cancelación de Hipoteca", Opcional = true },
    new DocEC { Id = "CLG", Parte = "Vendedor", Categoria = "LEGAL", Nombre = "Certificado de Libertad de Gravamen" }, 
    new DocEC { Id = "REC_AGUA", Parte = "Vendedor", Categoria = "LEGAL", Nombre = "Servicio de Agua RECIBO vigente" },
    new DocEC { Id = "REC_LUZ", Parte = "Vendedor", Categoria = "LEGAL", Nombre = "Servicio de Luz RECIBO vigente" },
    new DocEC { Id = "REC_TEL", Parte = "Vendedor", Categoria = "LEGAL", Nombre = "Servicio Teléfono", Opcional = true },
    new DocEC { Id = "CORRESP", Parte = "Vendedor", Categoria = "LEGAL", Nombre = "Correspondencia c/domicilio inmueble", Opcional = true },
    new DocEC { Id = "PLN", Parte = "Vendedor", Categoria = "TÉCNICO", Nombre = "Planos Arquitectónicos o Croquis", Opcional = true },

    // --- 3. COMERCIAL ---
    new DocEC { Id = "AV_PRIV", Parte = "Vendedor", Categoria = "COMERCIAL", Nombre = "Aviso de Privacidad / acuse firmar" },
    new DocEC { Id = "CART_DER", Parte = "Vendedor", Categoria = "COMERCIAL", Nombre = "Carta de derechos Vendedor / acuse firmar" },
    new DocEC { Id = "PROM_COMP", Parte = "Vendedor", Categoria = "COMERCIAL", Nombre = "Contrato de promesa de Compraventa" },
    new DocEC { Id = "CON", Parte = "Vendedor", Categoria = "COMERCIAL", Nombre = "Contrato de Intermediación" },
    new DocEC { Id = "INV", Parte = "Vendedor", Categoria = "COMERCIAL", Nombre = "Inventario Inmueble" },

    // --- 4. TRÁMITES Y NOTARÍA ---
    new DocEC { Id = "PAGO_PRED", Parte = "Vendedor", Categoria = "NOTARÍA", Nombre = "Comprobante pago Predial" },
    new DocEC { Id = "NAP", Parte = "Vendedor", Categoria = "NOTARÍA", Nombre = "Constancia de No Adeudo Predial" },
    new DocEC { Id = "CED", Parte = "Vendedor", Categoria = "NOTARÍA", Nombre = "Cédula Catastral Actualizada" },
    new DocEC { Id = "NAA", Parte = "Vendedor", Categoria = "NOTARÍA", Nombre = "Constancia de No Adeudo Agua CAPA" },
    new DocEC { Id = "COOP_OBRA", Parte = "Vendedor", Categoria = "NOTARÍA", Nombre = "Constancia de Cooperación por obra" },
    new DocEC { Id = "CAMB_PROP", Parte = "Vendedor", Categoria = "NOTARÍA", Nombre = "Cambio de Propietario" },
    new DocEC { Id = "NOMENCL", Parte = "Vendedor", Categoria = "NOTARÍA", Nombre = "Constancia de Nomenclatura" },
    new DocEC { Id = "NAO", Parte = "Vendedor", Categoria = "NOTARÍA", Nombre = "Pago de derecho obra pública municipal" },

    // ==========================================
    // 🔵 PESTAÑA: COMPRADOR
    // ==========================================
    new DocEC { Id = "COMP_ID", Parte = "Comprador", Categoria = "PERSONAL", Nombre = "Identificación Oficial (Frontal)" },
    new DocEC { Id = "COMP_ID_REV", Parte = "Comprador", Categoria = "PERSONAL", Nombre = "Identificación Oficial (Reverso)" },
    new DocEC { Id = "COMP_ACT_NAC", Parte = "Comprador", Categoria = "PERSONAL", Nombre = "Acta de Nacimiento" },
    new DocEC { Id = "COMP_ACT_MAT", Parte = "Comprador", Categoria = "PERSONAL", Nombre = "Acta de Matrimonio", Opcional = true },
    new DocEC { Id = "COMP_EDO_CTA", Parte = "Comprador", Categoria = "FINANCIERO", Nombre = "Último Estado de Cuenta Bancario" },
    new DocEC { Id = "COMP_RFC", Parte = "Comprador", Categoria = "FISCAL", Nombre = "Constancia de Situación Fiscal" },
    new DocEC { Id = "COMP_CURP", Parte = "Comprador", Categoria = "PERSONAL", Nombre = "CURP Vigente" },    // Antes: Id = "COMP_DOM"
    new DocEC { Id = "VEND_DOM", Parte = "Vendedor", Categoria = "PERSONAL", Nombre = "Comprobante de Domicilio" },
};
    protected override async Task OnInitializedAsync()
    {
        try
        {
            // 0. 🕵️‍♂️ Le preguntamos a Firebase quién está viendo esta pantalla
            var usuarioSesion = await JS.InvokeAsync<Models.UsuarioLogueado>("obtenerUsuarioActual");
            string miCorreo = usuarioSesion?.email?.ToLower() ?? "";

            // 1. Buscamos este expediente en Firestore usando la función JS que ya tienes
            var jsonExpediente = await JS.InvokeAsync<string>("obtenerUnicoExpediente", Id);

            if (!string.IsNullOrEmpty(jsonExpediente))
            {
                var opciones = new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true };

                // 🪄 Traducimos TODO el expediente y salvamos los colaboradores
                expedienteSeleccionado = System.Text.Json.JsonSerializer.Deserialize<Expediente>(jsonExpediente, opciones) ?? new Expediente();

                // 2. Extraer el Checklist de Documentos
                using var documentoJson = System.Text.Json.JsonDocument.Parse(jsonExpediente);
                if (documentoJson.RootElement.TryGetProperty("Documentos", out var docsElement))
                {
                    var documentosGuardados = System.Text.Json.JsonSerializer.Deserialize<List<DocEC>>(docsElement.GetRawText(), opciones);

                    if (documentosGuardados != null && documentosGuardados.Count > 0)
                    {
                        ChecklistDocs = documentosGuardados;
                    }
                }

                // 3. 🛡️ NUEVO CANDADO BLINDADO: Detectar si es un invitado por su ROL real
                bool esRolColaborador = false;
                
                // Le preguntamos a Firebase el rol oficial de esta persona en la app
                if (!string.IsNullOrEmpty(miCorreo))
                {
                    var jsonPermisos = await JS.InvokeAsync<string?>("obtenerRolUsuario", miCorreo);
                    if (!string.IsNullOrEmpty(jsonPermisos))
                    {
                        var perfilUsuario = System.Text.Json.JsonSerializer.Deserialize<UsuarioPermisos>(jsonPermisos, opciones);
                        
                        // Si su rol principal dice "colaborador", encendemos la alarma
                        if (perfilUsuario?.Rol?.ToLower() == "colaborador")
                        {
                            esRolColaborador = true;
                        }
                    }
                }

                // Activamos el modo restringido y escondemos botones SI:
                // A) Su rol oficial es "Colaborador" (No importa qué expediente sea)
                // B) O si está en la lista de invitados y NO es el dueño.
                if (esRolColaborador || 
                   (expedienteSeleccionado.Colaboradores != null && 
                    expedienteSeleccionado.Colaboradores.Contains(miCorreo) && 
                    expedienteSeleccionado.AsesorOwnerEmail?.ToLower() != miCorreo))
                {
                    esSoloColaborador = true; // ¡Se activa el modo restringido!
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error al cargar el progreso del expediente: {ex.Message}");
        }
    }

    private async Task HandleFileSelected(InputFileChangeEventArgs e, DocEC doc)
    {
        var formatosPermitidos = new[] { "application/pdf" };

        if (formatosPermitidos.Contains(e.File.ContentType))
        {
            try
            {
                // 1. Preparamos el archivo (Límite de 15MB)
                using var stream = e.File.OpenReadStream(maxAllowedSize: 15 * 1024 * 1024);
                using var streamRef = new DotNetStreamReference(stream);

                // 2. Llamamos a nuestra función de JS pasándole el ID del expediente y el tipo de archivo
                var urlDescarga = await JS.InvokeAsync<string>("subirArchivoStorage", Id, doc.Id, streamRef, e.File.ContentType);

                if (!string.IsNullOrEmpty(urlDescarga))
                {
                    // 1. Marcamos la casilla en verde en la memoria
                    doc.Cargado = true;
                    
                    // 🪄 EL ESLABÓN PERDIDO: Guardamos el link oficial de Firebase
                    doc.UrlArchivo = urlDescarga;

                    // 2. ¡EL PASO CLAVE! Guardamos este cambio en Firestore.
                    await JS.InvokeVoidAsync("actualizarDocumentosExpediente", Id, ChecklistDocs); 

                    // 3. Actualizamos la pantalla
                    StateHasChanged();
                }
            }
            catch (Exception ex)
            {
                await JS.InvokeVoidAsync("alert", $"Error al subir el archivo: {ex.Message}");
            }
        }
        else
        {
            await JS.InvokeVoidAsync("alert", "Por favor, selecciona solo archivos PDF .");
        }
    }
    private async Task BorrarDocumentoIndividual(DocEC doc)
    {
        // Opcional: Podrías poner una confirmación aquí si quieres, 
        // pero como pueden volver a subirlo fácilmente, lo borramos directo.
        try
        {
            // 1. Borramos físicamente el archivo de la nube usando la función JS que ya creamos
            await JS.InvokeVoidAsync("borrarArchivoStorage", Id, doc.Id);

            // 2. Apagamos la palomita en la memoria de la pantalla
            doc.Cargado = false;

            // 3. Le avisamos a Firestore que este archivo ya no está
            await JS.InvokeVoidAsync("actualizarDocumentosExpediente", Id, ChecklistDocs);

            // 4. Refrescamos la pantalla (esto hará que el botón de InputFile vuelva a aparecer)
            StateHasChanged();
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"Error al borrar: {ex.Message}");
        }
    }
    private async Task VerDocumento(DocEC doc)
    {
        try
        {
            // Le pasamos el ID del expediente y el ID del documento a JavaScript
            await JS.InvokeVoidAsync("abrirArchivoStorage", Id, doc.Id);
        }
        catch (Exception ex)
        {
            await JS.InvokeVoidAsync("alert", $"No se pudo abrir el documento: {ex.Message}");
        }
    }

    private async Task ProcesarEnvio(string formatoDescarga)
    {
        // 1. Validación de seguridad
        if (!TodosCargados)
        {
            await JS.InvokeVoidAsync("alert", "⚠️ Faltan documentos obligatorios.");
            return;
        }

        // 2. Personalización del mensaje según el botón presionado
        string mensajeConfirmacion = formatoDescarga == "ZIP" 
            ? "¿Preparar y descargar carpeta con todos los archivos separados?" 
            : "¿Unir todos los documentos y descargar en un solo PDF?";

        bool confirmado = await JS.InvokeAsync<bool>("confirm", 
            $"{mensajeConfirmacion}\n\nComenzará la cuenta regresiva de 10 días para su eliminación de la nube.");

        if (confirmado)
        {
            // 🟢 Encendemos pantalla de carga (Sticky)
            estaDescargando = true;
            StateHasChanged();

            try
            {
                // --- 🪄 LIMPIEZA DE NOMBRE PROFUNDA ---
                // Extraemos el ID o el nombre de la propiedad
                string nombreOriginal = expedienteSeleccionado?.Id ?? "Expediente";
                
                // Limpiamos espacios y PUNTOS para evitar que el navegador se confunda
                // De "EC0110.02" pasará a "EC0110_02"
                string nombreLimpio = nombreOriginal
                    .Replace(" ", "_")
                    .Replace(".", "_")
                    .ToUpper();

                // --- 📦 PREPARACIÓN DE DATOS ---
                // Convertimos la lista de documentos a JSON para el puente con JS
                var checklistJson = System.Text.Json.JsonSerializer.Serialize(ChecklistDocs);

                // --- 🚀 LLAMADA A JAVASCRIPT ---
                // Aquí enviamos el formato ("ZIP" o "PDF") para que JS sepa qué generar
                await JS.InvokeVoidAsync("descargarRespaldoExpediente", nombreLimpio, checklistJson, formatoDescarga);

                // 3. Registro de cierre en Firestore
                var datosCierre = new 
                { 
                    Estatus = "Enviado a Notaría", 
                    FechaEnvio = DateTime.UtcNow.ToString("o") 
                };
                await JS.InvokeVoidAsync("sellarExpedienteFirestore", Id, datosCierre);

                // 4. Notificación final al usuario
                await JS.InvokeVoidAsync("alert", $"✅ ¡Expediente procesado! El archivo '{nombreLimpio}' se ha descargado.");
            }
            catch (Exception ex)
            {
                await JS.InvokeVoidAsync("alert", $"Error crítico: {ex.Message}");
            }
            finally
            {
                // 🔴 Apagamos pantalla de carga pase lo que pase
                estaDescargando = false;
                StateHasChanged();
            }
        }
    }
    private string nuevoColaboradorEmail = "";

    private async Task AgregarColaborador()
    {
        if (string.IsNullOrWhiteSpace(nuevoColaboradorEmail) || !nuevoColaboradorEmail.Contains("@")) return;

        string emailLimpio = nuevoColaboradorEmail.Trim().ToLower();

        if (expedienteSeleccionado.Colaboradores == null)
            expedienteSeleccionado.Colaboradores = new List<string>();

        if (!expedienteSeleccionado.Colaboradores.Contains(emailLimpio))
        {
            expedienteSeleccionado.Colaboradores.Add(emailLimpio);

            // 🔥 NUEVA LLAMADA ANTI-BORRADOS
            await JS.InvokeVoidAsync("agregarColaboradorFirebase", Id, emailLimpio);
        }

        nuevoColaboradorEmail = ""; 
    }

    private async Task EliminarColaborador(string email)
{
    if (expedienteSeleccionado.Colaboradores != null)
    {
        expedienteSeleccionado.Colaboradores.Remove(email);
        
        // Avisamos a Blazor que repinte la pantalla para que desaparezca el nombre
        StateHasChanged(); 

        await JS.InvokeVoidAsync("eliminarColaboradorFirebase", Id, email);
    }
}
    

    public class DocEC
    {
        public string Id { get; set; } = string.Empty;
        public string Parte { get; set; } = "Vendedor";
        public string Categoria { get; set; } = string.Empty;
        public string Nombre { get; set; } = string.Empty;
        public bool Cargado { get; set; }
        public bool Opcional { get; set; }
        public string UrlArchivo { get; set; } = string.Empty;
    }
}