@page "/expediente" 
@page "/expediente/{Id}"
@using Microsoft.AspNetCore.Components.Forms
@using static InmoCierres.Pages.Home

@inject NavigationManager Navigation
@inject IJSRuntime JS   
    @if (estaDescargando)
    {
        <div style="position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; background-color: rgba(0, 0, 0, 0.85); z-index: 9999; display: flex; flex-direction: column; justify-content: center; align-items: center;">
            <div class="spinner-border text-success" role="status" style="width: 4rem; height: 4rem; border-width: 0.4rem;">
                <span class="visually-hidden">Procesando...</span>
            </div>
            <h3 class="text-white mt-4 fw-bold">Generando archivo...</h3>
            <p class="text-light text-center px-4">Descargando y empaquetando los documentos de la nube.<br/>Por favor, espera unos segundos y no cierres esta página.</p>
        </div>
    }
<div class="expediente-container p-3">
    <div class="d-flex align-items-center sticky-top bg-white py-3 mb-4" style="z-index: 1020; top: 0; border-bottom: 1px solid #f0f0f0;">
    <button class="btn btn-link text-dark p-0 me-3" @onclick='() => Navigation.NavigateTo("")'>
        <i class="bi bi-arrow-left" style="font-size: 1.5rem;"></i>
    </button>
    <h3 class="fw-bold mb-0">Expediente @Id</h3>
</div>
    
    <div class="alert alert-warning border-0 shadow-sm rounded-4 mb-4">
        <div class="d-flex">
            <i class="bi bi-exclamation-triangle-fill me-3 fs-4"></i>
            <div>
                <strong>Estándar de Calidad:</strong> Solo se admiten archivos <b>PDF</b> escaneados. 
                <br><small>Las fotos de cámara no cumplen con el estándar de comercialización.</small>
            </div>
        </div>
    </div>
    
    @* --- SECCIÓN: COMPARTIR EXPEDIENTE EC0110.02 --- *@
    <div class="card shadow-sm border-0 mb-4 rounded-4 bg-light">
        <div class="card-body p-3">
            <div class="d-flex align-items-center justify-content-between mb-2">
                <h6 class="fw-bold mb-0" style="color: var(--brand-black);">
                    <i class="bi bi-people-fill text-primary me-2"></i> Asesores Colaboradores
                </h6>
                <span class="badge bg-white text-dark border">
                    @(expedienteSeleccionado.Colaboradores?.Count ?? 0) accesos
                </span>
            </div>
            
            <p class="text-muted small mb-3">Agrega el correo del asesor colega para que pueda subir documentos a este expediente.</p>
             
            @if (!esSoloColaborador)
            {
            <div class="d-flex gap-2 mb-3">
                <input type="email" class="form-control form-control-sm rounded-3" @bind="nuevoColaboradorEmail" placeholder="ejemplo@remax.com" />
                <button class="btn btn-sm btn-dark px-3 rounded-3 fw-bold" @onclick="AgregarColaborador">
                    Invitar
                </button>
            </div>
            }
            @if (expedienteSeleccionado.Colaboradores != null && expedienteSeleccionado.Colaboradores.Any())
            {
                <div class="d-flex flex-wrap gap-2">
                    @foreach (var email in expedienteSeleccionado.Colaboradores)
                    {
                        <span class="badge border text-dark shadow-sm px-2 py-1 d-flex align-items-center gap-2" style="background-color: #fff;">
                            <i class="bi bi-person-circle text-muted"></i> @email
                            
                            @* 🔥 EL ESCUDO DOBLE: Solo mostramos la X si tienes permisos Y no es el correo del dueño original *@
                            @if (!esSoloColaborador && email.ToLower() != expedienteSeleccionado.AsesorOwnerEmail?.ToLower())
                            {
                                <i class="bi bi-x-circle-fill text-danger" style="cursor: pointer;" @onclick="() => EliminarColaborador(email)"></i>
                            }
                        </span>
                    }
                </div>
            }
        </div>
    </div>
    @* --- FIN SECCIÓN COMPARTIR --- *@
@* --- MENÚ DE PESTAÑAS (TABS) --- *@
<ul class="nav nav-tabs nav-fill mb-4 border-bottom-0 shadow-sm rounded-top-4 overflow-hidden" style="background-color: #f8f9fa;">
    <li class="nav-item">
        <button class="nav-link border-0 py-3 @(pestanaActiva == "Vendedor" ? "active bg-white text-primary fw-bold border-bottom border-primary border-3" : "text-muted")"
                @onclick='() => pestanaActiva = "Vendedor"'>
            <i class="bi bi-person-badge me-2"></i>Expediente Vendedor
        </button>
    </li>
    <li class="nav-item">
        <button class="nav-link border-0 py-3 @(pestanaActiva == "Comprador" ? "active bg-white text-primary fw-bold border-bottom border-primary border-3" : "text-muted")"
                @onclick='() => pestanaActiva = "Comprador"'>
            <i class="bi bi-person-bounding-box me-2"></i>Expediente Comprador
        </button>
    </li>
</ul>

@* --- LISTA DE DOCUMENTOS FILTRADA --- *@
<div class="tab-content">
    @* OJO AQUÍ: Este es el nuevo foreach con el filtro mágico *@
    @* --- LISTA DE DOCUMENTOS FILTRADA --- *@
<div class="tab-content">
    @foreach (var doc in ChecklistDocs.Where(d => d.Parte == pestanaActiva))
{
    <div class="card mb-3 shadow-sm rounded-4 @(doc.Parte == "Comprador" ? "border-primary border-opacity-25" : "border-0") @(doc.Cargado ? "bg-light border-success border-opacity-50" : "")">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-start mb-2">
                    <div>
                        <h6 class="mb-0 fw-bold">
                            @doc.Nombre
                            @if (doc.Opcional)
                            {
                                <span class="text-muted fw-normal" style="font-size: 0.75rem;">(Si aplica)</span>
                            }
                        </h6>
                        <span class="badge border text-dark mt-1" 
                            style="font-size: 0.7rem; background-color: @(doc.Categoria == "NOTARÍA" ? "#e0f2fe" : doc.Categoria == "PERSONAL" ? "#fef08a" : doc.Categoria == "FINANCIERO" ? "#dcfce7" : "#f3f4f6");">
                            @doc.Categoria
                        </span>
                    </div>
                    @if (doc.Cargado)
                    {
                        <i class="bi bi-check-circle-fill text-success fs-4"></i>
                    }
                </div>
                
                <div class="mt-2">
                    @if (doc.Cargado)
                    {
                        <div class="d-flex gap-2 w-100">
                            <button class="btn btn-sm btn-outline-primary flex-fill rounded-3 fw-bold shadow-sm" @onclick="() => VerDocumento(doc)">
                                <i class="bi bi-eye me-1"></i> Ver
                            </button>
                            <button class="btn btn-sm btn-outline-danger flex-fill rounded-3 fw-bold shadow-sm" @onclick="() => BorrarDocumentoIndividual(doc)">
                                <i class="bi bi-arrow-repeat me-1"></i> Reemplazar
                            </button>
                        </div>
                    }
                    else
                    {
                        <InputFile OnChange="@(e => HandleFileSelected(e, doc))" accept="application/pdf" class="form-control form-control-sm rounded-3 shadow-sm" />
                    }
                </div>
            </div>
        </div>
    }
</div>
    
</div>
    <div class="d-flex gap-3 mt-4 mb-5">
        <button class="btn btn-outline-primary flex-fill fw-bold py-3 rounded-4 shadow-sm" 
                @onclick='() => ProcesarEnvio("PDF")'>
            <i class="bi bi-file-earmark-pdf-fill fs-5 me-2 d-block mb-1"></i> 
            Guardar y enviar<br><small class="fw-normal">en 1 solo PDF</small>
        </button>
        
        <button class="btn btn-primary flex-fill fw-bold py-3 rounded-4 shadow-sm text-white" 
                style="background-color: var(--brand-black); border: none;"
                @onclick='() => ProcesarEnvio("ZIP")'>
            <i class="bi bi-folder-fill fs-5 me-2 d-block mb-1 text-warning"></i> 
            Guardar y preparar<br><small class="fw-normal">Carpeta de archivos</small>
        </button>
    </div>
</div>

@code {
    private string pestanaActiva = "Vendedor";
    private bool estaDescargando = false;
    private bool esSoloColaborador = false;
    [Parameter] public string Id { get; set; } = string.Empty;
    private Expediente expedienteSeleccionado = new Expediente();

    private bool TodosCargados => ChecklistDocs.Where(d => !d.Opcional).All(d => d.Cargado);

    private List<DocEC> ChecklistDocs = new()
{
    // ==========================================
    // 🟠 PESTAÑA: VENDEDOR
    // ==========================================
    // --- 1. PERSONAL ---
    new DocEC { Id = "ID", Parte = "Vendedor", Categoria = "PERSONAL", Nombre = "Identificación Oficial (Frontal)" },
